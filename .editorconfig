root = true

[*]
indent_style = tab
indent_size = tab
tab_width = 2
end_of_line = lf
max_line_length = 120

[*.md]
indent_style = space
indent_size = 2
max_line_length = 240

[*.json]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2
