{
  "name": "phi-monorepo",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./packages/pi-*/extensions"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "check": "bun run --filter '*' check",
    "test:agent": "bun run --cwd packages/phi test:agent && bun run --cwd packages/pi-web test:agent",
    "tui": "bun run --cwd packages/phi tui",
    "dev:service": "bun run --cwd packages/phi dev:service",
    "dev:service:prompt": "bun run --cwd packages/phi dev:service:prompt"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
